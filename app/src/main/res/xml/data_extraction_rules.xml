<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for Android 12+ (dataExtractionRules).
   Exclude the location database (sensitive data) from both
   cloud backup and device-to-device transfer.
   DataStore preferences are still backed up.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="loctracker.db" />
        <exclude domain="database" path="loctracker.db-shm" />
        <exclude domain="database" path="loctracker.db-wal" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="loctracker.db" />
        <exclude domain="database" path="loctracker.db-shm" />
        <exclude domain="database" path="loctracker.db-wal" />
    </device-transfer>
</data-extraction-rules>
