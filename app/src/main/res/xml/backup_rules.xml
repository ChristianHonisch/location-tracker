<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules for Android < 12 (fullBackupContent).
   Exclude the location database (sensitive data) but allow
   DataStore preferences to be backed up.
-->
<full-backup-content>
    <exclude domain="database" path="loctracker.db" />
    <exclude domain="database" path="loctracker.db-shm" />
    <exclude domain="database" path="loctracker.db-wal" />
</full-backup-content>
